# Copy to .env and fill in. Never commit the real .env.
# Full reference: docs/SPEC.md §9
#
# DATABASE_URL / SEARXNG_URL / CRAWL4AI_URL below use `localhost` for
# running the app directly on the host (against services with published
# ports). Under docker-compose, these three are overridden to internal
# service DNS names (postgres/searxng/crawl4ai) — see docker-compose.yml —
# and those backing services do NOT publish ports to the host at all.
#
# PROJECT_PREFIX is read only by docker-compose.yml (variable substitution
# from this file), not by the app itself — it names/prefixes every
# container so this deployment is easy to find with `docker ps` on a
# shared host, and so two checkouts can coexist with different prefixes.
# Not consumed by the Settings class (extra="ignore"), so it's harmless
# for the containers to also see it as an env var.
PROJECT_PREFIX=deep-research-backend

# Host-side port docker-compose.yml publishes `api` on (container-internal
# port is always 8000 — only this host mapping changes). Not read by the
# app itself (extra="ignore"); useful to change on a shared host to avoid
# colliding with other projects' ports.
API_PORT=8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/deep_research

# Secure by default (true). Set to false ONLY for a deployment that's
# already network-isolated to trusted callers (e.g. firewalled to a VPN /
# internal network) — disabling this removes the only access control this
# API has, it does not add any other restriction in its place.
REQUIRE_API_KEY=true

SEARCH_PROVIDER=searxng
SEARXNG_URL=http://localhost:8080
# Required by the searxng service in docker-compose.yml (compose fails fast
# if unset). Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SEARXNG_SECRET=

# Only read when SEARCH_PROVIDER=composite — fans out to SearXNG plus any
# enabled extra sources below and merges by weighted round-robin (never a
# blended cross-source score — see composite_provider.py). Unset/default
# SEARCH_PROVIDER=searxng ignores everything in this block entirely.
SEARCH_SEARXNG_WEIGHT=1.0
SEARCH_COMPOSITE_TIMEOUT_SECONDS=15.0

# Reddit's public, unauthenticated search.json endpoint — no API key
# needed. Disabled by default; SEARCH_REDDIT_MAX_RESULTS caps how many of
# the final merged results can come from Reddit, regardless of how many it
# returns.
SEARCH_REDDIT_ENABLED=false
SEARCH_REDDIT_WEIGHT=0.4
SEARCH_REDDIT_MAX_RESULTS=2
SEARCH_REDDIT_BASE_URL=https://www.reddit.com
SEARCH_REDDIT_USER_AGENT=DeepResearchBackend/1.0

# GitHub's official repository search API — reliable and structured,
# unlike Reddit/X's scraping-based alternatives. Works unauthenticated (10
# req/min GitHub-enforced limit); an optional token raises that to 30
# req/min. Disabled by default.
SEARCH_GITHUB_ENABLED=false
SEARCH_GITHUB_WEIGHT=0.6
SEARCH_GITHUB_MAX_RESULTS=3
SEARCH_GITHUB_BASE_URL=https://api.github.com
SEARCH_GITHUB_TOKEN=

# Trump's Truth Social feed specifically — relevant only for markets about
# his statements/policy, noise for everything else. Kept at a low weight
# and small cap by design (see truth_social_provider.py); raise the weight
# only for a deployment/use case that's genuinely mostly Trump-related
# markets.
SEARCH_TRUTH_SOCIAL_ENABLED=false
SEARCH_TRUTH_SOCIAL_WEIGHT=0.2
SEARCH_TRUTH_SOCIAL_MAX_RESULTS=2
SEARCH_TRUTH_SOCIAL_BASE_URL=https://truthsocial.com

# Off by default (empty = today's direct connections, unchanged). Set to
# route this app's own outbound requests through a proxy: applies to the
# Reddit/GitHub/Truth Social search providers (SEARCH_PROVIDER=composite
# only) and to Crawl4AI's page fetch below. Format:
# "http://[user:pass@]host:port" or "socks5://host:port".
# Does NOT affect SearXNG: this app's call to SEARXNG_URL is to the
# internal searxng service, not a public site, and SearXNG's own outbound
# proxy for its engine queries is a separate setting — see
# deploy/searxng/settings.yml.
OUTBOUND_PROXY_URL=

CRAWL_PROVIDER=crawl4ai
CRAWL4AI_URL=http://localhost:11235
# Required — Crawl4AI refuses to bind beyond loopback (127.0.0.1) without
# this set, which would make it unreachable from api/worker over the
# docker network. Also enforced as a Bearer auth header on every request.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
CRAWL4AI_API_TOKEN=

RESEARCH_EXECUTION_MODE_DEFAULT=blocking

CRAWL_MAX_RESPONSE_BYTES=5000000
CRAWL_FETCH_TIMEOUT_SECONDS=20
CRAWL_PER_DOMAIN_CONCURRENCY=2

JOB_MAX_ATTEMPTS=3
WORKER_POLL_INTERVAL_SECONDS=1

TTL_DOCS_DAYS=30
TTL_GITHUB_DAYS=7
TTL_BLOG_DAYS=7
TTL_NEWS_HOURS=6
