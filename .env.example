# Copy to .env and fill in. Never commit the real .env.
# Full reference: docs/SPEC.md §9
#
# DATABASE_URL / SEARXNG_URL / CRAWL4AI_URL below use `localhost` for
# running the app directly on the host (against services with published
# ports). Under docker-compose, these three are overridden to internal
# service DNS names (postgres/searxng/crawl4ai) — see docker-compose.yml —
# and those backing services do NOT publish ports to the host at all.
#
# PROJECT_PREFIX is read only by docker-compose.yml (variable substitution
# from this file), not by the app itself — it names/prefixes every
# container so this deployment is easy to find with `docker ps` on a
# shared host, and so two checkouts can coexist with different prefixes.
# Not consumed by the Settings class (extra="ignore"), so it's harmless
# for the containers to also see it as an env var.
PROJECT_PREFIX=deep-research-backend

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/deep_research

SEARCH_PROVIDER=searxng
SEARXNG_URL=http://localhost:8080
# Required by the searxng service in docker-compose.yml (compose fails fast
# if unset). Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SEARXNG_SECRET=

CRAWL_PROVIDER=crawl4ai
CRAWL4AI_URL=http://localhost:11235
# Required — Crawl4AI refuses to bind beyond loopback (127.0.0.1) without
# this set, which would make it unreachable from api/worker over the
# docker network. Also enforced as a Bearer auth header on every request.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
CRAWL4AI_API_TOKEN=

RESEARCH_EXECUTION_MODE_DEFAULT=blocking

CRAWL_MAX_RESPONSE_BYTES=5000000
CRAWL_FETCH_TIMEOUT_SECONDS=20
CRAWL_PER_DOMAIN_CONCURRENCY=2

JOB_MAX_ATTEMPTS=3
WORKER_POLL_INTERVAL_SECONDS=1

TTL_DOCS_DAYS=30
TTL_GITHUB_DAYS=7
TTL_BLOG_DAYS=7
TTL_NEWS_HOURS=6
